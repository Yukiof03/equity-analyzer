# ----- 必須 -----
# Anthropic API キー（https://console.anthropic.com/ で発行）
ANTHROPIC_API_KEY=sk-ant-...

# ----- オプション -----
# 1IPあたり1時間あたりのリクエスト上限（デフォルト10）
RATE_LIMIT_PER_HOUR=10

# 簡易アクセストークン（設定するとフロントエンドにこのトークンが必要になる）
# 公開URLでも社内限定にしたい場合に利用
# ACCESS_TOKEN=your-shared-secret

# 利用可能モデル（カンマ区切り、未設定ならデフォルトリスト）
# ALLOWED_MODELS=claude-sonnet-4-5,claude-sonnet-4-6,claude-opus-4-6
